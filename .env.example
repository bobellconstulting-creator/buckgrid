# BuckGrid Pro — Environment Variables
# Copy this file to .env.local and fill in your keys

# Primary vision model (Gemini 2.5 Flash — preferred)
GOOGLE_API_KEY=your_google_api_key_here
NEURADEX_GOOGLE_API_KEY=your_google_api_key_here

# Fallback vision model (GPT-4o)
OPENAI_API_KEY=your_openai_api_key_here

# Production URL
NEXT_PUBLIC_APP_URL=https://www.buckgridpro.com
